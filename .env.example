# =============================================================================
# STABILITY INTELLIGENCE SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual credentials
# See BLOCKERS.md for missing/optional credentials

# -----------------------------------------------------------------------------
# Neo4j Configuration
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# -----------------------------------------------------------------------------
# LiteLLM Configuration
# -----------------------------------------------------------------------------
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=your-litellm-master-key-here
LITELLM_CLAUDE_MODEL=claude-3-sonnet-20240229
LITELLM_KIMI_MODEL=moonshot-v1-8k

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------
# Anthropic (Claude) - REQUIRED for reasoning tasks
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Kimi (Moonshot AI) - REQUIRED for ingestion
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_API_KEY=sk-xxxxx

# GLM (Zhipu AI) - OPTIONAL fallback model
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=xxxxx

# -----------------------------------------------------------------------------
# GitHub Configuration
# -----------------------------------------------------------------------------
# GitHub Personal Access Token with repo scope
GITHUB_TOKEN=ghp_xxxxx
GITHUB_REPO=juspay/hyperswitch
GITHUB_SYNC_INTERVAL_HOURS=6

# -----------------------------------------------------------------------------
# Langfuse (LLM Observability)
# -----------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=sk-lf-xxxxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
LANGFUSE_HOST=http://langfuse:3000

# -----------------------------------------------------------------------------
# DeepWiki MCP (Optional - for architecture queries)
# -----------------------------------------------------------------------------
DEEPWIKI_MCP_URL=http://deepwiki-mcp:3100

# -----------------------------------------------------------------------------
# Local Repository Path
# -----------------------------------------------------------------------------
HYPERSWITCH_REPO_PATH=/app/hyperswitch-repo

# -----------------------------------------------------------------------------
# Alerting (Optional)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# -----------------------------------------------------------------------------
# Scheduler Configuration
# -----------------------------------------------------------------------------
# Cron expression for weekly strategy agent run (default: Monday 9 AM)
STRATEGY_AGENT_CRON=0 9 * * 1

# -----------------------------------------------------------------------------
# Dashboard Configuration
# -----------------------------------------------------------------------------
DASHBOARD_PORT=8080
